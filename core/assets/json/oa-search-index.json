{{- $records := slice -}}
{{- range .Site.Sites -}}
  {{- $lang := .Language.Lang -}}
  {{- $langLabel := .Language.LanguageName | default $lang -}}
  {{- $topicLabels := dict -}}
  {{- range .Data.topics -}}
    {{- $topicLabels = merge $topicLabels (dict .id (index .title $lang | default .id)) -}}
  {{- end -}}
  {{- $items := where .RegularPages "Section" "items" -}}
  {{- range $items -}}
    {{- $topicRefs := slice -}}
    {{- $allTopics := (.Params.topics | default (slice)) -}}
    {{- with .Params.primary_topic -}}
      {{- $allTopics = $allTopics | append . -}}
    {{- end -}}
    {{- range $allTopics -}}
      {{- $topicRefs = $topicRefs | append (dict
        "id" .
        "label" (index $topicLabels . | default .)
        "url" (printf "topics/%s/" . | relLangURL)
      ) -}}
    {{- end -}}
    {{- $record := dict
      "title" .Title
      "url" .RelPermalink
      "lang" $lang
      "language_label" $langLabel
      "source_date" (.Params.source_date | default "")
      "submission_date" (.Params.submission_date | default "")
      "source_type" (.Params.source_type | default "")
      "topics" $topicRefs
      "executive_summary" (.Params.executive_summary | default "")
      "detailed_notes" (.Params.detailed_notes | default "")
      "content" (.Content | plainify | htmlUnescape | strings.TrimSpace)
    -}}
    {{- $records = $records | append $record -}}
  {{- end -}}
{{- end -}}
{{- $records | jsonify -}}
